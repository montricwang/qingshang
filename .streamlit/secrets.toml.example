# Public demo does not call PostgreSQL, the LLM provider, or CNKGraph.
PUBLIC_DEMO_MODE = true
QINGSHANG_API_BASE_URL = "http://127.0.0.1:8000"
QINGSHANG_REVIEW_TIMEOUT_SECONDS = "180"

# For a real deployment, configure these in the platform secret store.
# Never commit real values in secrets.toml.
DATABASE_URL = ""
LLM_API_KEY = ""
LLM_BASE_URL = "https://api.deepseek.com"
LLM_MODEL = "deepseek-chat"
CNKGRAPH_BASE_URL = "https://api.cnkgraph.com"
